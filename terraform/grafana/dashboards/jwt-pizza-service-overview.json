{
  "uid": "jwt-pizza-overview",
  "title": "JWT Pizza Service Overview",
  "tags": ["jwt-pizza", "terraform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Requests",
      "gridPos": { "h": 10, "w": 16, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "grafanacloud-prom" },
      "targets": [
        {
          "expr": "http_requests_total{service=\"jwt-pizza-service\",environment=\"$environment\"}",
          "legendFormat": "Total",
          "refId": "A"
        },
        {
          "expr": "http_requests_get_total{service=\"jwt-pizza-service\",environment=\"$environment\"}",
          "legendFormat": "GET",
          "refId": "B"
        },
        {
          "expr": "http_requests_post_total{service=\"jwt-pizza-service\",environment=\"$environment\"}",
          "legendFormat": "POST",
          "refId": "C"
        },
        {
          "expr": "http_requests_put_total{service=\"jwt-pizza-service\",environment=\"$environment\"}",
          "legendFormat": "PUT",
          "refId": "D"
        },
        {
          "expr": "http_requests_delete_total{service=\"jwt-pizza-service\",environment=\"$environment\"}",
          "legendFormat": "DELETE",
          "refId": "E"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          },
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "barWidthFactor": 0.6,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {
              "type": "linear"
            },
            "showPoints": "auto",
            "showValues": false,
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        }
      }
    },
    {
      "id": 2,
