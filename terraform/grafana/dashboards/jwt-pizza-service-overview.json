{
	"uid": "jwt-pizza-overview",
	"title": "JWT Pizza Service Overview",
	"tags": ["jwt-pizza", "terraform"],
	"timezone": "browser",
	"schemaVersion": 39,
	"version": 1,
	"editable": true,
	"refresh": "30s",
	"panels": [
		{
			"id": 1,
			"type": "timeseries",
			"title": "HTTP Requests",
			"gridPos": {
				"h": 14,
				"w": 24,
				"x": 0,
				"y": 0
			},
			"datasource": {
				"type": "prometheus",
				"uid": "grafanacloud-prom"
			},
			"targets": [
				{
					"expr": "http_requests_total{source=\"jwt-pizza-service-dev\"}",
					"legendFormat": "Total",
					"refId": "A"
				},
				{
					"expr": "http_requests_get{source=\"jwt-pizza-service-dev\"}",
					"legendFormat": "GET",
					"refId": "B"
				},
				{
					"expr": "http_requests_post{source=\"jwt-pizza-service-dev\"}",
					"legendFormat": "POST",
					"refId": "C"
				},
				{
					"expr": "http_requests_put{source=\"jwt-pizza-service-dev\"}",
					"legendFormat": "PUT",
					"refId": "D"
				},
				{
					"expr": "http_requests_delete{source=\"jwt-pizza-service-dev\"}",
					"legendFormat": "DELETE",
					"refId": "E"
				}
			],
			"fieldConfig": {
				"defaults": {
					"custom": {
						"drawStyle": "line",
						"lineWidth": 2,
						"fillOpacity": 10,
						"gradientMode": "scheme",
						"spanNulls": true,
						"pointSize": 5,
						"showPoints": "auto"
					},
					"color": {
						"mode": "palette-classic"
					}
				}
			},
			"options": {
				"tooltip": {
					"mode": "multi",
					"sort": "desc"
				},
				"legend": {
					"displayMode": "table",
					"placement": "right",
					"calcs": ["lastNotNull"]
				}
			}
		}
	],
	"templating": {
		"list": []
	},
	"time": {
		"from": "now-1h",
		"to": "now"
	},
	"timepicker": {},
	"annotations": {
		"list": []
	}
}